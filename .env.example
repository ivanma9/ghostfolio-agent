# ─────────────────────────────────────────────────────────────────────────────
# ghostfolio-agent — environment variable template
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
# Anthropic API key for Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Ghostfolio ────────────────────────────────────────────────────────────────
# Base URL of the Ghostfolio instance the agent will call.
# When using the dev compose stack this is always http://localhost:3333.
GHOSTFOLIO_BASE_URL=http://localhost:3333

# Bearer token for Ghostfolio API requests.
# Obtain this from the Ghostfolio UI after the first run:
#   Settings → Security → Generate API key  (or copy from the login response)
GHOSTFOLIO_ACCESS_TOKEN=

# ── LangSmith tracing ────────────────────────────────────────────────────────
# LangSmith API key for LangChain observability (https://smith.langchain.com)
LANGSMITH_API_KEY=ls__...

# Enable LangChain tracing (set to false to disable)
LANGCHAIN_TRACING_V2=true

# LangSmith project name traces will be grouped under
LANGCHAIN_PROJECT=ghostfolio-agent

# ── Agent server ─────────────────────────────────────────────────────────────
# Port the agent's HTTP server (FastAPI / Flask / etc.) will listen on
AGENT_PORT=8000

# Logging verbosity: debug | info | warning | error
LOG_LEVEL=debug

# ── 3rd Party Data APIs ────────────────────────────────────────────────────
# Finnhub API key for earnings, analyst recs, congressional trades (https://finnhub.io)
FINNHUB_API_KEY=

# Alpha Vantage API key for news sentiment, macro indicators (https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=
