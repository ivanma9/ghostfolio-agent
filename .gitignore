# ─────────────────────────────────────────────────────────────────────────────
# ghostfolio-agent .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# pip / uv / poetry lock artifacts (keep lock files, ignore caches)
pip-log.txt
pip-delete-this-directory.txt
.pip-cache/
.uv/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/

# mypy / ruff / pyright caches
.mypy_cache/
.ruff_cache/
.pyright/
pyrightconfig.json

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Docker ───────────────────────────────────────────────────────────────────
# Local volume data mounted from Docker containers
docker/volumes/
volumes/
postgres_data/
redis_data/

# ── IDE / editor ─────────────────────────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# Cursor
.cursor/

# Claude Code
.claude/

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ── Logs / runtime artifacts ─────────────────────────────────────────────────
*.log
logs/
*.pid

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
.cache/
*.pdf

# ── Data (runtime) ───────────────────────────────────────────────────────────
data/
.worktrees/
